# pnpm build-script allowlist lives in package.json -> pnpm.onlyBuiltDependencies.
# ignore-scripts=true prevents package lifecycle scripts (e.g. preinstall) from
# running when this package is installed via plain `npm install`, which may lack
# a POSIX shell (`sh`) needed to run those scripts. pnpm overrides this setting
# for packages listed in pnpm.onlyBuiltDependencies (root package scripts also
# still run under pnpm, so `pnpm build` / `pnpm pack` are unaffected).
ignore-scripts=true
